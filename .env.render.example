SERVER_ENV="staging"

APP_DOMAIN="staging.example.com"
API_DOMAIN="api-staging.example.com"

WEB_PORT="3000"
API_PORT="10000"

DATABASE_URL="postgresql://postgres.PROJECT_REF:<PASSWORD_URL_ENCODED>@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.PROJECT_REF:<PASSWORD_URL_ENCODED>@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

JWT_SECRET="<RENDER_JWT_SECRET>"
JWT_EXPIRES_IN="7d"

FRONTEND_URL="https://staging.example.com"
CORS_ORIGIN="https://staging.example.com"
CORS_ORIGINS="https://staging.example.com,https://www.staging.example.com"

NEXT_PUBLIC_API_URL="https://api-staging.example.com/api"

TRUST_PROXY="true"
JSON_BODY_LIMIT="1mb"
API_RATE_LIMIT_WINDOW_MS="900000"
API_RATE_LIMIT_MAX="500"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://api-staging.example.com/api/auth/oauth/google/callback"

FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
FACEBOOK_CALLBACK_URL="https://api-staging.example.com/api/auth/oauth/facebook/callback"

OAUTH_STATE_SECRET="<RENDER_OAUTH_STATE_SECRET>"

NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<SUPABASE_PUBLISHABLE_KEY>"

RIOT_API_MODE="mock"
RIOT_API_KEY=""
RIOT_REGION="la1"
RIOT_REGIONAL_ROUTE="americas"
RIOT_API_TIMEOUT_MS="8000"

RIOT_TOURNAMENT_API_ENABLED="false"
RIOT_CALLBACK_URL=""
RIOT_TOURNAMENT_PROVIDER_ID=""
RIOT_TOURNAMENT_CALLBACK_SECRET=""
RIOT_TOURNAMENT_ID=""

RIOT_RSO_CLIENT_ID=""
RIOT_RSO_CLIENT_SECRET=""
RIOT_RSO_REDIRECT_URI=""
RIOT_RSO_SCOPES="openid offline_access"
